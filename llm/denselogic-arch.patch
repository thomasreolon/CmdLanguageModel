diff --git a/src/models/denselogic.cpp b/src/models/denselogic.cpp
new file mode 100644
index 0000000..e974814
--- /dev/null
+++ b/src/models/denselogic.cpp
@@ -0,0 +1,140 @@
+#include "models.h"
+
+// DenseLogic (hh_llm arch #2): 6 blocks alternating RoPE attention (even il) and the
+// invented "logicsim" register-machine mixer (odd il), wired with DENSE SKIP connections
+// — block l reads a learned softmax-weighted combo of all earlier states H_0..H_l.
+// SwiGLU MLP + RMSNorm. All inference-static pieces (skip softmax weights, EMA kernel)
+// are baked into tensors by the converter, so the graph uses only standard ggml ops.
+
+void llama_model_denselogic::load_arch_hparams(llama_model_loader & ml) {
+    ml.get_key(LLM_KV_ATTENTION_LAYERNORM_RMS_EPS, hparams.f_norm_rms_eps);
+    type = LLM_TYPE_SMALL;
+}
+
+void llama_model_denselogic::load_arch_tensors(llama_model_loader & ml) {
+    LLAMA_LOAD_LOCALS;
+
+    tok_embd    = create_tensor(tn(LLM_TENSOR_TOKEN_EMBD,  "weight"), {n_embd, n_vocab}, 0);
+    output_norm = create_tensor(tn(LLM_TENSOR_OUTPUT_NORM, "weight"), {n_embd}, 0);
+    output      = create_tensor(tn(LLM_TENSOR_OUTPUT,      "weight"), {n_embd, n_vocab}, TENSOR_NOT_REQUIRED);
+    if (output == nullptr) {  // tied head
+        output  = create_tensor(tn(LLM_TENSOR_TOKEN_EMBD, "weight"), {n_embd, n_vocab}, TENSOR_DUPLICATED);
+    }
+
+    for (int i = 0; i < n_layer; ++i) {
+        auto & layer = layers[i];
+        layer.attn_norm = create_tensor(tn(LLM_TENSOR_ATTN_NORM, "weight", i), {n_embd}, 0);
+        layer.skip_w    = create_tensor(tn(LLM_TENSOR_SKIP_W,    "weight", i), {i + 1}, 0);  // convex over H_0..H_i
+
+        if (i % 2 == 0) {  // attention + SwiGLU block
+            layer.wqkv     = create_tensor(tn(LLM_TENSOR_ATTN_QKV, "weight", i), {n_embd, 3 * n_embd}, 0);
+            layer.wo       = create_tensor(tn(LLM_TENSOR_ATTN_OUT, "weight", i), {n_embd, n_embd}, 0);
+            layer.ffn_norm = create_tensor(tn(LLM_TENSOR_FFN_NORM, "weight", i), {n_embd}, 0);
+            layer.ffn_gate = create_tensor(tn(LLM_TENSOR_FFN_GATE, "weight", i), {n_embd, n_ff}, 0);
+            layer.ffn_up   = create_tensor(tn(LLM_TENSOR_FFN_UP,   "weight", i), {n_embd, n_ff}, 0);
+            layer.ffn_down = create_tensor(tn(LLM_TENSOR_FFN_DOWN, "weight", i), {n_ff, n_embd}, 0);
+        } else {           // logicsim block (mlp:none)
+            layer.logic_in    = create_tensor(tn(LLM_TENSOR_LOGIC_IN,    "weight", i), {n_embd, 3 * n_embd}, 0);
+            layer.logic_alu   = create_tensor(tn(LLM_TENSOR_LOGIC_ALU,   "weight", i), {2 * n_embd, n_embd}, 0);
+            layer.logic_out   = create_tensor(tn(LLM_TENSOR_LOGIC_OUT,   "weight", i), {n_embd, n_embd}, 0);
+            layer.logic_ema_k = create_tensor(tn(LLM_TENSOR_LOGIC_EMA_K, "weight", i), {n_ctx_train, 1, n_embd}, 0);
+        }
+    }
+}
+
+std::unique_ptr<llm_graph_context> llama_model_denselogic::build_arch_graph(const llm_graph_params & params) const {
+    return std::make_unique<graph>(*this, params);
+}
+
+llama_model_denselogic::graph::graph(const llama_model & model, const llm_graph_params & params)
+        : llm_graph_context(params) {
+    const int64_t n_embd_head = hparams.n_embd_head_v();
+    const int64_t C = n_embd;
+
+    ggml_tensor * inpL    = build_inp_embd(model.tok_embd);   // H_0  [C, T]
+    ggml_tensor * inp_pos = build_inp_pos();
+    auto *        inp_attn   = build_attn_inp_kv();
+    ggml_tensor * inp_out_ids = build_inp_out_ids();
+
+    // logicsim mixer: differentiable register machine (see hh_llm logicsim.py)
+    auto logicsim = [&](const llama_layer & L, ggml_tensor * x) -> ggml_tensor * {
+        const int64_t T = x->ne[1];
+        ggml_tensor * vgg = build_lora_mm(L.logic_in, x);                          // [3C, T]
+        ggml_tensor * v    = ggml_cont(ctx0, ggml_view_2d(ctx0, vgg, C, T, vgg->nb[1], 0 * C * sizeof(float)));
+        ggml_tensor * gin  = ggml_cont(ctx0, ggml_view_2d(ctx0, vgg, C, T, vgg->nb[1], 1 * C * sizeof(float)));
+        ggml_tensor * gout = ggml_cont(ctx0, ggml_view_2d(ctx0, vgg, C, T, vgg->nb[1], 2 * C * sizeof(float)));
+        gin  = ggml_sigmoid(ctx0, gin);
+        gout = ggml_sigmoid(ctx0, gout);
+        ggml_tensor * written = ggml_mul(ctx0, gin, v);                            // [C, T]
+
+        // port 1 — exact gated running mean: cumsum over time (ggml_cumsum runs on ne0,
+        // so transpose time into ne0, cumsum, transpose back).
+        ggml_tensor * num = ggml_cumsum(ctx0, ggml_cont(ctx0, ggml_transpose(ctx0, written)));
+        num = ggml_cont(ctx0, ggml_transpose(ctx0, num));                          // [C, T]
+        ggml_tensor * den = ggml_cumsum(ctx0, ggml_cont(ctx0, ggml_transpose(ctx0, gin)));
+        den = ggml_cont(ctx0, ggml_transpose(ctx0, den));                          // [C, T]
+        ggml_tensor * counter = ggml_div(ctx0, num, den);
+
+        // port 2 — multi-scale EMA via depthwise causal conv with the baked kernel.
+        // conv_1d_dw wants data [L, C]; pad K-1 on the left, keep the first T outputs.
+        ggml_tensor * data = ggml_cont(ctx0, ggml_transpose(ctx0, written));        // [T, C]
+        const int K = (int) L.logic_ema_k->ne[0];                                   // kernel length
+        ggml_tensor * ker = ggml_cast(ctx0, L.logic_ema_k, GGML_TYPE_F16);          // im2col wants F16
+        ggml_tensor * ema = ggml_conv_1d_dw(ctx0, ker, data, 1, K - 1, 1);          // pad K-1 (causal)
+        ema = ggml_cont(ctx0, ggml_view_2d(ctx0, ema, T, C, ema->nb[1], 0));        // first T -> [T, C]
+        ema = ggml_cont(ctx0, ggml_transpose(ctx0, ema));                          // [C, T]
+
+        ggml_tensor * memory = ggml_add(ctx0, counter, ema);
+        ggml_tensor * fused  = build_lora_mm(L.logic_alu, ggml_concat(ctx0, v, memory, 0));  // [C, T]
+        ggml_tensor * y = ggml_mul(ctx0, ggml_silu(ctx0, fused), gout);
+        return build_lora_mm(L.logic_out, y);                                      // [C, T]
+    };
+
+    std::vector<ggml_tensor *> hs = { inpL };                 // H_0 .. H_n_layer
+
+    for (int il = 0; il < n_layer; ++il) {
+        const llama_layer & L = model.layers[il];
+
+        // dense skip: inp = sum_k softmax(skip_w)_k * H_k   (broadcast each scalar weight)
+        ggml_tensor * inp = nullptr;
+        for (int k = 0; k <= il; ++k) {
+            ggml_tensor * wk   = ggml_view_1d(ctx0, L.skip_w, 1, k * sizeof(float));
+            ggml_tensor * term = ggml_mul(ctx0, hs[k], wk);
+            inp = inp ? ggml_add(ctx0, inp, term) : term;
+        }
+
+        ggml_tensor * cur = build_norm(inp, L.attn_norm, nullptr, LLM_NORM_RMS, il);  // norm1
+
+        if (il % 2 == 0) {  // RoPE attention, then residual; SwiGLU, then residual
+            auto [Q, K, V] = build_qkv(L, cur, n_embd_head, n_head, n_head_kv, il);
+            Q = ggml_rope_ext(ctx0, Q, inp_pos, nullptr, n_rot, rope_type, n_ctx_orig,
+                              freq_base, freq_scale, ext_factor, attn_factor, beta_fast, beta_slow);
+            K = ggml_rope_ext(ctx0, K, inp_pos, nullptr, n_rot, rope_type, n_ctx_orig,
+                              freq_base, freq_scale, ext_factor, attn_factor, beta_fast, beta_slow);
+            cur = build_attn(inp_attn, L.wo, L.wo_b, L.wo_s, Q, K, V, nullptr, nullptr, nullptr,
+                             1.0f / sqrtf(float(n_embd_head)), il);
+            ggml_tensor * x1 = ggml_add(ctx0, inp, cur);
+            ggml_tensor * f  = build_norm(x1, L.ffn_norm, nullptr, LLM_NORM_RMS, il);  // norm2
+            f = build_ffn(f, L.ffn_up, nullptr, nullptr, L.ffn_gate, nullptr, nullptr,
+                          L.ffn_down, nullptr, nullptr, nullptr, LLM_FFN_SILU, LLM_FFN_PAR, il);
+            cur = ggml_add(ctx0, x1, f);
+        } else {            // logicsim, then residual (no MLP)
+            cur = ggml_add(ctx0, inp, logicsim(L, cur));
+        }
+        cb(cur, "l_out", il);
+        hs.push_back(cur);
+    }
+
+    ggml_tensor * cur = hs.back();
+    if (inp_out_ids) {
+        cur = ggml_get_rows(ctx0, cur, inp_out_ids);          // keep only requested positions
+    }
+    cur = build_norm(cur, model.output_norm, nullptr, LLM_NORM_RMS, -1);            // ln_f
+    res->t_embd = cur;
+
+    cur = build_lora_mm(model.output, cur);
+    cb(cur, "result_output", -1);
+    res->t_logits = cur;
+
+    ggml_build_forward_expand(gf, cur);
+}
