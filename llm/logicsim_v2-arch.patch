diff --git a/src/models/logicsim_v2.cpp b/src/models/logicsim_v2.cpp
new file mode 100644
index 0000000..3b2bef2
--- /dev/null
+++ b/src/models/logicsim_v2.cpp
@@ -0,0 +1,191 @@
+#include "models.h"
+
+// LogicSimV2 (hh_llm arch, models/components/mixers/logicsim_v2.py): a plain prenorm
+// residual stack (NO dense skips) where every block's mixer runs, on an asymmetric channel
+// split, a DifferentialAttention branch (first c1 channels) in parallel with the LogicSim
+// register-machine branch (last c2 channels); the two are concatenated and passed through
+// one outer projection, then a SwiGLU MLP. RMSNorm throughout; RoPE only on the DiffAttn
+// branch's q/k. Geometry: c1 = 2*n_head*d_k (DiffAttn uses 2*n_head q/k head-groups of
+// width d_k and n_head v-heads of width d_v = 2*d_k); c2 = n_embd - c1.
+//
+// Inference-static pieces are baked into tensors by the converter, so the graph uses only
+// standard ggml ops: the DiffAttn `lambda` is one scalar/layer (blk.l.da_lambda) and the
+// LogicSim per-channel EMA decay is the causal conv kernel (blk.l.logic_ema_k).
+// Attention is computed cache-free with an explicit causal mask
+// (ggml_diag_mask_inf); the runner re-decodes the full sequence each step (logicsim is
+// recurrent), so no KV cache is consulted.
+
+void llama_model_logicsim_v2::load_arch_hparams(llama_model_loader & ml) {
+    ml.get_key(LLM_KV_ATTENTION_LAYERNORM_RMS_EPS, hparams.f_norm_rms_eps);
+    type = LLM_TYPE_SMALL;
+}
+
+void llama_model_logicsim_v2::load_arch_tensors(llama_model_loader & ml) {
+    LLAMA_LOAD_LOCALS;
+
+    const int64_t hd_k = hparams.n_embd_head_k();   // q/k head width (32)
+    const int64_t hd_v = hparams.n_embd_head_v();   // v head width (64 = 2*hd_k)
+    const int64_t c1   = 2 * n_head * hd_k;         // DiffAttn branch width (384)
+    const int64_t c2   = n_embd - c1;               // LogicSim branch width (128)
+
+    tok_embd    = create_tensor(tn(LLM_TENSOR_TOKEN_EMBD,  "weight"), {n_embd, n_vocab}, 0);
+    output_norm = create_tensor(tn(LLM_TENSOR_OUTPUT_NORM, "weight"), {n_embd}, 0);
+    output      = create_tensor(tn(LLM_TENSOR_OUTPUT,      "weight"), {n_embd, n_vocab}, TENSOR_NOT_REQUIRED);
+    if (output == nullptr) {  // tied head
+        output  = create_tensor(tn(LLM_TENSOR_TOKEN_EMBD, "weight"), {n_embd, n_vocab}, TENSOR_DUPLICATED);
+    }
+
+    for (int i = 0; i < n_layer; ++i) {
+        auto & layer = layers[i];
+        layer.attn_norm   = create_tensor(tn(LLM_TENSOR_ATTN_NORM,   "weight", i), {n_embd}, 0);
+        // DiffAttn branch (c1)
+        layer.da_qkv      = create_tensor(tn(LLM_TENSOR_DA_QKV,      "weight", i), {c1, 3 * c1}, 0);
+        layer.da_out      = create_tensor(tn(LLM_TENSOR_DA_OUT,      "weight", i), {c1, c1}, 0);
+        layer.da_subln    = create_tensor(tn(LLM_TENSOR_DA_SUBLN,    "weight", i), {hd_v}, 0);
+        layer.da_lambda   = create_tensor(tn(LLM_TENSOR_DA_LAMBDA,   "weight", i), {1}, 0);
+        // LogicSim branch (c2)
+        layer.logic_in    = create_tensor(tn(LLM_TENSOR_LOGIC_IN,    "weight", i), {c2, 3 * c2}, 0);
+        layer.logic_alu   = create_tensor(tn(LLM_TENSOR_LOGIC_ALU,   "weight", i), {2 * c2, c2}, 0);
+        layer.logic_out   = create_tensor(tn(LLM_TENSOR_LOGIC_OUT,   "weight", i), {c2, c2}, 0);
+        layer.logic_ema_k = create_tensor(tn(LLM_TENSOR_LOGIC_EMA_K, "weight", i), {n_ctx_train, 1, c2}, 0);
+        // outer post-concat projection + SwiGLU MLP
+        layer.mix_out     = create_tensor(tn(LLM_TENSOR_MIX_OUT,     "weight", i), {n_embd, n_embd}, 0);
+        layer.ffn_norm    = create_tensor(tn(LLM_TENSOR_FFN_NORM,    "weight", i), {n_embd}, 0);
+        layer.ffn_gate    = create_tensor(tn(LLM_TENSOR_FFN_GATE,    "weight", i), {n_embd, n_ff}, 0);
+        layer.ffn_up      = create_tensor(tn(LLM_TENSOR_FFN_UP,      "weight", i), {n_embd, n_ff}, 0);
+        layer.ffn_down    = create_tensor(tn(LLM_TENSOR_FFN_DOWN,    "weight", i), {n_ff, n_embd}, 0);
+    }
+}
+
+std::unique_ptr<llm_graph_context> llama_model_logicsim_v2::build_arch_graph(const llm_graph_params & params) const {
+    return std::make_unique<graph>(*this, params);
+}
+
+llama_model_logicsim_v2::graph::graph(const llama_model & model, const llm_graph_params & params)
+        : llm_graph_context(params) {
+    const int64_t hd_k = hparams.n_embd_head_k();    // 32
+    const int64_t hd_v = hparams.n_embd_head_v();    // 64
+    const int64_t H    = n_head;                      // 6 DiffAttn v-heads
+    const int64_t c1   = 2 * H * hd_k;               // 384
+    const int64_t c2   = n_embd - c1;                // 128
+    const float   kq_scale    = 1.0f / sqrtf((float) hd_k);
+    const float   subln_scale = 1.0f - 0.8f;         // (1 - lambda_init)
+
+    ggml_tensor * inpL        = build_inp_embd(model.tok_embd);
+    ggml_tensor * inp_pos     = build_inp_pos();
+    ggml_tensor * inp_out_ids = build_inp_out_ids();
+
+    // one causal attention: q,k = [hd_k, H, T], v = [hd_v, H, T] -> [c1=H*hd_v, T]
+    auto attn_one = [&](ggml_tensor * q, ggml_tensor * k, ggml_tensor * v) -> ggml_tensor * {
+        const int64_t T = q->ne[2];
+        ggml_tensor * qp = ggml_cont(ctx0, ggml_permute(ctx0, q, 0, 2, 1, 3));   // [hd_k, T, H]
+        ggml_tensor * kp = ggml_cont(ctx0, ggml_permute(ctx0, k, 0, 2, 1, 3));   // [hd_k, T, H]
+        ggml_tensor * kq = ggml_mul_mat(ctx0, kp, qp);                           // [T, T, H]
+        ggml_mul_mat_set_prec(kq, GGML_PREC_F32);
+        kq = ggml_scale(ctx0, kq, kq_scale);
+        kq = ggml_diag_mask_inf(ctx0, kq, 0);                                    // causal
+        kq = ggml_soft_max(ctx0, kq);
+        ggml_tensor * vp = ggml_cont(ctx0, ggml_permute(ctx0, v, 0, 2, 1, 3));   // [hd_v, T, H]
+        vp = ggml_cont(ctx0, ggml_transpose(ctx0, vp));                          // [T, hd_v, H]
+        ggml_tensor * kqv = ggml_mul_mat(ctx0, vp, kq);                          // [hd_v, T, H]
+        ggml_tensor * o = ggml_permute(ctx0, kqv, 0, 2, 1, 3);                   // [hd_v, H, T]
+        return ggml_cont_2d(ctx0, o, hd_v * H, T);                               // [c1, T]
+    };
+
+    // DifferentialAttention on the first c1 channels (see diffattn.py / logicsim_v2.py)
+    auto diffattn = [&](const llama_layer & L, ggml_tensor * x1) -> ggml_tensor * {
+        const int64_t T = x1->ne[1];
+        ggml_tensor * qkv = build_lora_mm(L.da_qkv, x1);                         // [3c1, T]
+        ggml_tensor * q = ggml_cont(ctx0, ggml_view_2d(ctx0, qkv, c1, T, qkv->nb[1], 0 * c1 * sizeof(float)));
+        ggml_tensor * k = ggml_cont(ctx0, ggml_view_2d(ctx0, qkv, c1, T, qkv->nb[1], 1 * c1 * sizeof(float)));
+        ggml_tensor * v = ggml_cont(ctx0, ggml_view_2d(ctx0, qkv, c1, T, qkv->nb[1], 2 * c1 * sizeof(float)));
+        q = ggml_reshape_3d(ctx0, q, hd_k, 2 * H, T);                           // [hd_k, 2H, T]
+        k = ggml_reshape_3d(ctx0, k, hd_k, 2 * H, T);
+        v = ggml_reshape_3d(ctx0, v, hd_v, H, T);                               // [hd_v, H, T]
+        q = ggml_rope_ext(ctx0, q, inp_pos, nullptr, n_rot, rope_type, n_ctx_orig,
+                          freq_base, freq_scale, ext_factor, attn_factor, beta_fast, beta_slow);
+        k = ggml_rope_ext(ctx0, k, inp_pos, nullptr, n_rot, rope_type, n_ctx_orig,
+                          freq_base, freq_scale, ext_factor, attn_factor, beta_fast, beta_slow);
+        q = ggml_cont(ctx0, q);
+        k = ggml_cont(ctx0, k);
+        // interleaved even/odd q/k head groups (PyTorch q[:,0::2] / q[:,1::2])
+        ggml_tensor * q1 = ggml_cont(ctx0, ggml_view_3d(ctx0, q, hd_k, H, T, q->nb[1] * 2, q->nb[2], 0));
+        ggml_tensor * q2 = ggml_cont(ctx0, ggml_view_3d(ctx0, q, hd_k, H, T, q->nb[1] * 2, q->nb[2], q->nb[1]));
+        ggml_tensor * k1 = ggml_cont(ctx0, ggml_view_3d(ctx0, k, hd_k, H, T, k->nb[1] * 2, k->nb[2], 0));
+        ggml_tensor * k2 = ggml_cont(ctx0, ggml_view_3d(ctx0, k, hd_k, H, T, k->nb[1] * 2, k->nb[2], k->nb[1]));
+        ggml_tensor * a1 = attn_one(q1, k1, v);                                 // [c1, T]
+        ggml_tensor * a2 = attn_one(q2, k2, v);                                 // [c1, T]
+        ggml_tensor * y  = ggml_sub(ctx0, a1, ggml_mul(ctx0, a2, L.da_lambda)); // a1 - lambda*a2
+        // subln: RMSNorm over each head's hd_v, * weight, * (1 - lambda_init)
+        y = ggml_reshape_3d(ctx0, y, hd_v, H, T);
+        y = ggml_rms_norm(ctx0, y, hparams.f_norm_rms_eps);
+        y = ggml_mul(ctx0, y, L.da_subln);
+        y = ggml_scale(ctx0, y, subln_scale);
+        y = ggml_cont_2d(ctx0, y, c1, T);
+        return build_lora_mm(L.da_out, y);                                      // [c1, T]
+    };
+
+    // LogicSim on the last c2 channels: gated cumulative running-mean + multi-scale EMA
+    auto logicsim = [&](const llama_layer & L, ggml_tensor * x2) -> ggml_tensor * {
+        const int64_t T = x2->ne[1];
+        ggml_tensor * vgg = build_lora_mm(L.logic_in, x2);                      // [3c2, T]
+        ggml_tensor * v    = ggml_cont(ctx0, ggml_view_2d(ctx0, vgg, c2, T, vgg->nb[1], 0 * c2 * sizeof(float)));
+        ggml_tensor * gin  = ggml_cont(ctx0, ggml_view_2d(ctx0, vgg, c2, T, vgg->nb[1], 1 * c2 * sizeof(float)));
+        ggml_tensor * gout = ggml_cont(ctx0, ggml_view_2d(ctx0, vgg, c2, T, vgg->nb[1], 2 * c2 * sizeof(float)));
+        gin  = ggml_sigmoid(ctx0, gin);
+        gout = ggml_sigmoid(ctx0, gout);
+        ggml_tensor * written = ggml_mul(ctx0, gin, v);                         // [c2, T]
+
+        // port 1 — exact gated running mean (cumsum runs on ne0, so transpose time in/out)
+        ggml_tensor * num = ggml_cumsum(ctx0, ggml_cont(ctx0, ggml_transpose(ctx0, written)));
+        num = ggml_cont(ctx0, ggml_transpose(ctx0, num));                       // [c2, T]
+        ggml_tensor * den = ggml_cumsum(ctx0, ggml_cont(ctx0, ggml_transpose(ctx0, gin)));
+        den = ggml_cont(ctx0, ggml_transpose(ctx0, den));                       // [c2, T]
+        ggml_tensor * counter = ggml_div(ctx0, num, den);
+
+        // port 2 — multi-scale EMA via depthwise causal conv with the baked kernel
+        ggml_tensor * data = ggml_cont(ctx0, ggml_transpose(ctx0, written));    // [T, c2]
+        const int K = (int) L.logic_ema_k->ne[0];
+        ggml_tensor * ker = ggml_cast(ctx0, L.logic_ema_k, GGML_TYPE_F16);
+        ggml_tensor * ema = ggml_conv_1d_dw(ctx0, ker, data, 1, K - 1, 1);      // left-pad K-1 (causal)
+        ema = ggml_cont(ctx0, ggml_view_2d(ctx0, ema, T, c2, ema->nb[1], 0));   // first T -> [T, c2]
+        ema = ggml_cont(ctx0, ggml_transpose(ctx0, ema));                       // [c2, T]
+
+        ggml_tensor * memory = ggml_add(ctx0, counter, ema);
+        ggml_tensor * fused  = build_lora_mm(L.logic_alu, ggml_concat(ctx0, v, memory, 0));
+        ggml_tensor * y = ggml_mul(ctx0, ggml_silu(ctx0, fused), gout);
+        return build_lora_mm(L.logic_out, y);                                   // [c2, T]
+    };
+
+    ggml_tensor * cur = inpL;                                                   // [n_embd, T]
+    for (int il = 0; il < n_layer; ++il) {
+        const llama_layer & L = model.layers[il];
+
+        ggml_tensor * normed = build_norm(cur, L.attn_norm, nullptr, LLM_NORM_RMS, il);   // norm1
+        const int64_t T = normed->ne[1];
+        ggml_tensor * x1 = ggml_cont(ctx0, ggml_view_2d(ctx0, normed, c1, T, normed->nb[1], 0));
+        ggml_tensor * x2 = ggml_cont(ctx0, ggml_view_2d(ctx0, normed, c2, T, normed->nb[1], c1 * sizeof(float)));
+
+        ggml_tensor * mix = ggml_concat(ctx0, diffattn(L, x1), logicsim(L, x2), 0);        // [n_embd, T]
+        mix = build_lora_mm(L.mix_out, mix);
+        cur = ggml_add(ctx0, cur, mix);                                                    // residual
+
+        ggml_tensor * fn = build_norm(cur, L.ffn_norm, nullptr, LLM_NORM_RMS, il);          // norm2
+        fn = build_ffn(fn, L.ffn_up, nullptr, nullptr, L.ffn_gate, nullptr, nullptr,
+                       L.ffn_down, nullptr, nullptr, nullptr, LLM_FFN_SILU, LLM_FFN_PAR, il);
+        cur = ggml_add(ctx0, cur, fn);                                                     // residual
+        cb(cur, "l_out", il);
+    }
+
+    if (inp_out_ids) {
+        cur = ggml_get_rows(ctx0, cur, inp_out_ids);
+    }
+    cur = build_norm(cur, model.output_norm, nullptr, LLM_NORM_RMS, -1);                    // ln_f
+    res->t_embd = cur;
+
+    cur = build_lora_mm(model.output, cur);
+    cb(cur, "result_output", -1);
+    res->t_logits = cur;
+
+    ggml_build_forward_expand(gf, cur);
+}
